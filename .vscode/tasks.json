{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-build-debug",
      "type": "shell",
      "command": "cmake --build ./build/debug --config Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "cmake-build-release",
      "type": "shell",
      "command": "cmake --build ./build/release --config Release",
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "sync-shaders",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "Copy-Item -Path '${workspaceFolder}/shaders/*' -Destination '${workspaceFolder}/bin/debug/shaders/' -Recurse -Force; Copy-Item -Path '${workspaceFolder}/shaders/*' -Destination '${workspaceFolder}/bin/release/shaders/' -Recurse -Force"
      ],
      "presentation": {
      "reveal": "silent",
      "close": true
      },
      "problemMatcher": []
    }
  ]
}