{
  "triggerTaskOnSave.tasks": {
    "sync-shaders": [
      "shaders/*.glsl",
      "shaders/*.vert",
      "shaders/*.frag"
    ]
  },
  "clangd.arguments": [
    "--header-insertion=never",
    "--compile-commands-dir=${workspaceFolder}/build/${buildType}"
  ],
  "cmake.buildDirectory": "${workspaceFolder}/build/${buildType}",
}
